    \PYGZbs{} \PYG{p}{=} \PYG{l+s+s1}{\PYGZsq{}\PYGZhy{}\PYGZhy{}unique @pdf\PYGZbs{}\PYGZsh{}src:@tex:@line:@col\PYGZsq{}}

\PYG{k}{let} \PYG{k}{b}:vimtex\PYGZus{}main \PYG{p}{=} \PYG{l+s+s2}{\PYGZdq{}principal.tex\PYGZdq{}}     \PYG{c}{\PYGZdq{} Esto establece el archivo}
