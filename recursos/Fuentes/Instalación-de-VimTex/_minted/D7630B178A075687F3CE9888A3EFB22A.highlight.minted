\PYG{k}{let} \PYG{k}{g}:vimtex\PYGZus{}compiler\PYGZus{}latexmk \PYG{p}{=} \PYGZob{}
        \PYGZbs{} \PYG{l+s+s1}{\PYGZsq{}aux\PYGZus{}dir\PYGZsq{}} : \PYG{l+s+s1}{\PYGZsq{}build/\PYGZsq{}}\PYG{p}{,}
        \PYGZbs{} \PYG{l+s+s1}{\PYGZsq{}pdfxelatex\PYGZsq{}} : \PYG{l+s+s1}{\PYGZsq{}xelatex\PYGZsq{}}\PYG{p}{,}
	\PYGZbs{}\PYGZcb{}

