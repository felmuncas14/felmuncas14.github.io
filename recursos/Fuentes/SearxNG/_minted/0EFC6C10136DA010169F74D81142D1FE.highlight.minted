\PYG{+w}{  }\PYG{c+c1}{\PYGZsh{} suffix of searxng\PYGZus{}useragent, could contain information like an email address}
\PYG{+w}{  }\PYG{c+c1}{\PYGZsh{} to the administrator}
\PYG{+w}{  }\PYG{n+nt}{useragent\PYGZus{}suffix}\PYG{p}{:}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}\PYGZdq{}}
\PYG{+w}{  }\PYG{c+c1}{\PYGZsh{} The maximum number of concurrent connections that may be established.}
\PYG{+w}{  }\PYG{n+nt}{pool\PYGZus{}connections}\PYG{p}{:}\PYG{+w}{ }\PYG{l+lScalar+lScalarPlain}{100}
