\PYG{c+c1}{\PYGZsh{} communication with search engines}
\PYG{c+c1}{\PYGZsh{}}
\PYG{n+nt}{outgoing}\PYG{p}{:}
\PYG{+w}{  }\PYG{c+c1}{\PYGZsh{} default timeout in seconds, can be override by engine}
\PYG{+w}{  }\PYG{n+nt}{request\PYGZus{}timeout}\PYG{p}{:}\PYG{+w}{ }\PYG{l+lScalar+lScalarPlain}{6.0}
\PYG{+w}{  }\PYG{c+c1}{\PYGZsh{} the maximum timeout in seconds}
