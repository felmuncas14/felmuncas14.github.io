\PYG{c+c1}{\PYGZsh{} Configuration of the \PYGZdq{}Hostnames plugin\PYGZdq{}:}
\PYG{c+c1}{\PYGZsh{}}
\PYG{c+c1}{\PYGZsh{} hostnames:}
\PYG{c+c1}{\PYGZsh{}   replace:}
\PYG{c+c1}{\PYGZsh{}     \PYGZsq{}(.*\PYGZbs{}.)?youtube\PYGZbs{}.com\PYGZdl{}\PYGZsq{}: \PYGZsq{}yt.example.com\PYGZsq{}}
\PYG{c+c1}{\PYGZsh{}     \PYGZsq{}(.*\PYGZbs{}.)?youtu\PYGZbs{}.be\PYGZdl{}\PYGZsq{}: \PYGZsq{}yt.example.com\PYGZsq{}}
\PYG{c+c1}{\PYGZsh{}     \PYGZsq{}(.*\PYGZbs{}.)?reddit\PYGZbs{}.com\PYGZdl{}\PYGZsq{}: \PYGZsq{}teddit.example.com\PYGZsq{}}
\PYG{c+c1}{\PYGZsh{}     \PYGZsq{}(.*\PYGZbs{}.)?redd\PYGZbs{}.it\PYGZdl{}\PYGZsq{}: \PYGZsq{}teddit.example.com\PYGZsq{}}
\PYG{c+c1}{\PYGZsh{}     \PYGZsq{}(www\PYGZbs{}.)?twitter\PYGZbs{}.com\PYGZdl{}\PYGZsq{}: \PYGZsq{}nitter.example.com\PYGZsq{}}
\PYG{c+c1}{\PYGZsh{}   remove:}
\PYG{c+c1}{\PYGZsh{}     \PYGZhy{} \PYGZsq{}(.*\PYGZbs{}.)?facebook.com\PYGZdl{}\PYGZsq{}}
\PYG{c+c1}{\PYGZsh{}   low\PYGZus{}priority:}
\PYG{c+c1}{\PYGZsh{}     \PYGZhy{} \PYGZsq{}(.*\PYGZbs{}.)?google(\PYGZbs{}..*)?\PYGZdl{}\PYGZsq{}}
\PYG{c+c1}{\PYGZsh{}   high\PYGZus{}priority:}
\PYG{c+c1}{\PYGZsh{}     \PYGZhy{} \PYGZsq{}(.*\PYGZbs{}.)?wikipedia.org\PYGZdl{}\PYGZsq{}}
\PYG{c+c1}{\PYGZsh{}}
\PYG{c+c1}{\PYGZsh{} Alternatively you can use external files for configuring the \PYGZdq{}Hostnames plugin\PYGZdq{}:}
\PYG{c+c1}{\PYGZsh{}}
\PYG{c+c1}{\PYGZsh{} hostnames:}
\PYG{c+c1}{\PYGZsh{}  replace: \PYGZsq{}rewrite\PYGZhy{}hosts.yml\PYGZsq{}}
\PYG{c+c1}{\PYGZsh{}}
\PYG{c+c1}{\PYGZsh{} Content of \PYGZsq{}rewrite\PYGZhy{}hosts.yml\PYGZsq{} (place the file in the same directory as \PYGZsq{}settings.yml\PYGZsq{}):}
\PYG{c+c1}{\PYGZsh{} \PYGZsq{}(.*\PYGZbs{}.)?youtube\PYGZbs{}.com\PYGZdl{}\PYGZsq{}: \PYGZsq{}yt.example.com\PYGZsq{}}
\PYG{c+c1}{\PYGZsh{} \PYGZsq{}(.*\PYGZbs{}.)?youtu\PYGZbs{}.be\PYGZdl{}\PYGZsq{}: \PYGZsq{}yt.example.com\PYGZsq{}}
\PYG{c+c1}{\PYGZsh{}}

