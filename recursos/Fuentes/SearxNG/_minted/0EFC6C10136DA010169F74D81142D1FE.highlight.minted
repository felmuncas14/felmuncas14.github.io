\PYG{+w}{  }\PYG{c+c1}{\PYGZsh{} For this demo of the sqlite engine download:}
\PYG{+w}{  }\PYG{c+c1}{\PYGZsh{}   https://liste.mediathekview.de/filmliste\PYGZhy{}v2.db.bz2}
\PYG{+w}{  }\PYG{c+c1}{\PYGZsh{} and unpack into searx/data/filmliste\PYGZhy{}v2.db}
\PYG{+w}{  }\PYG{c+c1}{\PYGZsh{} Query to test: \PYGZdq{}!mediathekview concert\PYGZdq{}}
\PYG{+w}{  }\PYG{c+c1}{\PYGZsh{}}
\PYG{+w}{  }\PYG{c+c1}{\PYGZsh{} \PYGZhy{} name: mediathekview}
\PYG{+w}{  }\PYG{c+c1}{\PYGZsh{}   engine: sqlite}
\PYG{+w}{  }\PYG{c+c1}{\PYGZsh{}   shortcut: mediathekview}
\PYG{+w}{  }\PYG{c+c1}{\PYGZsh{}   categories: [general, videos]}
\PYG{+w}{  }\PYG{c+c1}{\PYGZsh{}   result\PYGZus{}type: MainResult}
\PYG{+w}{  }\PYG{c+c1}{\PYGZsh{}   database: searx/data/filmliste\PYGZhy{}v2.db}
\PYG{+w}{  }\PYG{c+c1}{\PYGZsh{}   query\PYGZus{}str: \PYGZgt{}\PYGZhy{}}
\PYG{+w}{  }\PYG{c+c1}{\PYGZsh{}     SELECT title || \PYGZsq{} (\PYGZsq{} || time(duration, \PYGZsq{}unixepoch\PYGZsq{}) || \PYGZsq{})\PYGZsq{} AS title,}
\PYG{+w}{  }\PYG{c+c1}{\PYGZsh{}            COALESCE( NULLIF(url\PYGZus{}video\PYGZus{}hd,\PYGZsq{}\PYGZsq{}), NULLIF(url\PYGZus{}video\PYGZus{}sd,\PYGZsq{}\PYGZsq{}), url\PYGZus{}video) AS url,}
\PYG{+w}{  }\PYG{c+c1}{\PYGZsh{}            description AS content}
\PYG{+w}{  }\PYG{c+c1}{\PYGZsh{}       FROM film}
\PYG{+w}{  }\PYG{c+c1}{\PYGZsh{}      WHERE title LIKE :wildcard OR description LIKE :wildcard}
\PYG{+w}{  }\PYG{c+c1}{\PYGZsh{}      ORDER BY duration DESC}

